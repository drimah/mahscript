{
  "manifest_version": 3,
  "name": "mahscript",
  "version": "2.0.0",
  "description": "Skins profissionais para Google Docs e gerenciador de capítulos integrado.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "mahscript"
  },
  "content_scripts": [
    {
      "matches": ["*://docs.google.com/document/d/*"],
      "js": [
        "content.js",
        "modules/title-sync.js",
        "modules/cover.js",
        "modules/chapters.js",
        "modules/settings-patch.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "manuscript/index.html",
        "manuscript/style.css",
        "manuscript/app.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}