{
  "manifest_version": 3,
  "name": "mahscript",
  "version": "1.0",
  "description": "Skins e recursos visuais para Google Docs",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "mahscript"
  },
  "content_scripts": [
    {
      "matches": ["*://docs.google.com/*"],
      "js": ["content.js"]
    }
  ]
}